    {
      "name": "Admin - Payments",
      "item": [
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/payments?page=1&limit=20\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "payments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "paymentMethod", "value": "", "disabled": true },
                { "key": "startDate", "value": "", "disabled": true },
                { "key": "endDate", "value": "", "disabled": true }
              ]
            },
            "description": "Get paginated list of payments with filters. status: pending | completed | failed | refunded. paymentMethod: paypal | bank_transfer"
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/payments/:paymentId\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "payments", ":paymentId"],
              "variable": [{ "key": "paymentId", "value": "{{paymentId}}" }]
            },
            "description": "Get detailed information about a specific payment."
          }
        },
        {
          "name": "Create Payment (Manual)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data) {",
                  "    pm.environment.set(\"paymentId\", jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentId}}",\n  \"enrollmentId": "{{enrollmentId}}",\n  \"amount\": 100,\n  \"paymentMethod\": "bank_transfer",\n  \"paymentDate\": "2026-02-26"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/payments\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "payments"]
            },
            "description": "Manually record a payment. paymentMethod: paypal | bank_transfer"
          }
        },
        {
          "name": "Mark Payment as Verified",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"TXN-123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/payments/:paymentId/verify\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "payments", ":paymentId", "verify"],
              "variable": [{ "key": "paymentId", "value": "{{paymentId}}" }]
            },
            "description": "Mark a pending payment as verified. Optionally add transaction ID."
          }
        },
        {
          "name": "Get Revenue Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/payments/summary/revenue\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "payments", "summary", "revenue"]
            },
            "description": "Get revenue summary: total this month/quarter/year, by payment method, by package type."
          }
        }
      ]
    },
