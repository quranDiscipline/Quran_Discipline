            },
            "description": "Assign a teacher to handle the booking request."
          }
        },
        {
          "name": "Confirm Booking with Zoom",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zoomLink\": \"https://zoom.us/j/123456789\",\n  \"confirmedDate\": \"2026-03-01\",\n  \"confirmedTime\": \"14:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/booking-requests/:bookingId/confirm\",
