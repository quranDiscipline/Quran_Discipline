{
  "info": {
    "_postman_id": "7bb10bff-137a-4aab-9ddd-d21a2f8cae99",
    "name": "Quran Discipline Academy API",
    "description": "API collection for Quran Discipline Academy - Auth, Users & Admin Portal (Phase 2-3)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "if (jsonData && jsonData.data && jsonData.data.user) {",
                  "    pm.environment.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.environment.set(\"tokenExpiry\", \"2024-01-01T00:00:00Z\");",
                  "    pm.environment.set(\"userId\", jsonData.data.user.id);",
                  "    pm.environment.set(\"userEmail\", jsonData.data.user.email);",
                  "    pm.environment.set(\"userRole\", jsonData.data.user.role);",
                  "    pm.environment.set(\"lastLoginEmail\", jsonData.data.user.email);",
                  "}",
                  "",
                  "pm.test('Response has success: true', () => {",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Response has accessToken', () => {",
                  "    pm.expect(jsonData.data).to.have.property('accessToken');",
                  "    pm.expect(jsonData.data).to.have.property('user');",
                  "});",
                  "",
                  "pm.test('Response has user data', () => {",
                  "    pm.expect(jsonData.data.user).to.have.property('id');",
                  "    pm.expect(jsonData.data.user).to.have.property('email');",
                  "    pm.expect(jsonData.data.user).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@qurandiscipline.academy\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate with email and password. Returns access token (15min expiry) and sets refresh token cookie (7 days)."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "const jsonData = pm.response.json();",
                  "pm.test('Response has success: true', () => { pm.expect(jsonData.success).to.be.true; });",
                  "if (pm.response.code === 200 && jsonData.success === true) {",
                  "    pm.environment.unset(\"accessToken\");",
                  "    pm.environment.unset(\"userId\");",
                  "    pm.environment.unset(\"userEmail\");",
                  "    pm.environment.unset(\"userRole\");",
                  "    pm.environment.unset(\"lastLoginEmail\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/auth/logout\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout user. Clears access token and removes refresh token cookie."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["auth", "refresh-token"]
            },
            "description": "Refresh access token using httpOnly refresh token cookie."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@qurandiscipline.academy\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Request password reset email. Sends reset token to user's email (valid for 1 hour)."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset-token-here\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Reset password using token from email. Token is single-use and expires after 1 hour."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@1234\",\n  \"newPassword\": \"NewPassword@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Change password for authenticated user. Requires current password."
          }
        }
      ],
      "description": "Authentication endpoints"
    },
    {
      "name": "Admin - Teachers",
      "item": [
        {
          "name": "Get All Teachers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/teachers?page=1&limit=20\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "isAvailable", "value": "", "disabled": true }
              ]
            },
            "description": "Get paginated list of teachers with optional search and availability filter."
          }
        },
        {
          "name": "Get Teacher by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/teachers/:teacherId\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers", ":teacherId"],
              "variable": [{ "key": "teacherId", "value": "{{teacherId}}" }]
            },
            "description": "Get detailed information about a specific teacher."
          }
        },
        {
          "name": "Create Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data) {",
                  "    pm.environment.set(\"teacherId\", jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"fullName\": \"Teacher Name\",\n  \"temporaryPassword\": \"Password123!\",\n  \"sex\": \"male\",\n  \"bio\": \"Experienced Quran teacher\",\n  \"qualifications\": [\"Ijazah in Quran\", \"10 years experience\"],\n  \"specializations\": [\"Tajweed\", \"Memorization\"],\n  \"hourlyRate\": 25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/teachers\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers"]
            },
            "description": "Create a new teacher account. User must change password on first login."
          }
        },
        {
          "name": "Update Teacher",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio\",\n  \"qualifications\": [\"Ijazah in Quran\", \"15 years experience\"],\n  \"specializations\": [\"Tajweed\", \"Memorization\", \"Islamic Studies\"],\n  \"hourlyRate\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/teachers/:teacherId\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers", ":teacherId"],
              "variable": [{ "key": "teacherId", "value": "{{teacherId}}" }]
            },
            "description": "Update teacher profile information."
          }
        },
        {
          "name": "Deactivate Teacher",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/teachers/:teacherId/deactivate\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers", ":teacherId", "deactivate"],
              "variable": [{ "key": "teacherId", "value": "{{teacherId}}" }]
            },
            "description": "Deactivate a teacher. Blocked if teacher has active enrollments."
          }
        },
        {
          "name": "Activate Teacher",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/teachers/:teacherId/activate\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers", ":teacherId", "activate"],
              "variable": [{ "key": "teacherId", "value": "{{teacherId}}" }]
            },
            "description": "Reactivate a deactivated teacher."
          }
        },
        {
          "name": "Get Teachers Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/teachers/stats\",
              \"host\": [\"{{baseUrl}}"],
              "path": ["admin", "teachers", "stats"]
            },
            "description": "Get teacher statistics: total, active, inactive, by specialization."
          }
        }
      ]
    },
