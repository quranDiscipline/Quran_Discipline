# ─── App ────────────────────────────────────────────────────────────────
# PURPOSE: Runtime environment flag
# WHERE: main.ts, app.module.ts
NODE_ENV=development

# PURPOSE: NestJS HTTP port
# WHERE: main.ts → app.listen()
PORT=3000

# PURPOSE: CORS whitelist for frontend origin
# WHERE: main.ts → app.enableCors()
FRONTEND_URL=http://localhost:5173

# ─── Database ───────────────────────────────────────────────────────────────
# PURPOSE: Prisma connection string to PostgreSQL
# WHERE: prisma/schema.prisma, PrismaService
DATABASE_URL=postgresql://postgres:password@localhost:5432/quran_academy_db

# ─── Redis ───────────────────────────────────────────────────────────────────
# PURPOSE: Redis connection (cache + Bull queues)
# WHERE: Future: cache.module.ts, bull.module.ts
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# PURPOSE: Sign access tokens (short-lived API credentials)
# WHERE: auth/strategies/jwt.strategy.ts, auth.service.ts
# EXAMPLE: Run `openssl rand -base64 64` to generate
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_min_64_chars

# PURPOSE: Sign refresh tokens (long-lived session tokens)
# WHERE: auth.service.ts → generateRefreshToken()
# EXAMPLE: Must be DIFFERENT from JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_min_64_chars

# PURPOSE: Access token lifespan (short — minimizes breach window)
# WHERE: auth.service.ts → jwt.sign()
JWT_ACCESS_EXPIRATION=15m

# PURPOSE: Refresh token lifespan (long — enables persistent sessions)
# WHERE: auth.service.ts → jwt.sign()
JWT_REFRESH_EXPIRATION=7d

# PURPOSE: bcrypt cost factor (higher = slower = more secure)
# WHERE: auth.service.ts → bcrypt.hash()
# EXAMPLE: 12 is production standard (do not go below 10)
BCRYPT_ROUNDS=12

# ─── Frontend ────────────────────────────────────────────────────────────────
# PURPOSE: Base URL for all axios API calls
# WHERE: frontend/src/lib/axios.ts
VITE_API_BASE_URL=http://localhost:3000/api

# PURPOSE: Socket.io connection endpoint
# WHERE: frontend/src/lib/socket.ts
VITE_WS_URL=http://localhost:3000
