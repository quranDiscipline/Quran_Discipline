# ─── App ────────────────────────────────────────────────────────────────
# PURPOSE: Runtime environment flag
# WHERE: main.ts, app.module.ts
NODE_ENV=development

# PURPOSE: NestJS HTTP port
# WHERE: main.ts → app.listen()
PORT=3000

# PURPOSE: CORS whitelist for frontend origin
# WHERE: main.ts → app.enableCors()
FRONTEND_URL=http://localhost:5173

# ─── Database ───────────────────────────────────────────────────────────────
# PURPOSE: Prisma connection string to PostgreSQL
# WHERE: prisma/schema.prisma, PrismaService
DATABASE_URL=postgresql://postgres:password@localhost:5432/quran_academy_db

# ─── Redis ───────────────────────────────────────────────────────────────────
# PURPOSE: Redis connection (cache + Bull queues)
# WHERE: Future: cache.module.ts, bull.module.ts
REDIS_URL=redis://localhost:6379

# ─── Frontend ────────────────────────────────────────────────────────────────
# PURPOSE: Base URL for all axios API calls
# WHERE: frontend/src/lib/axios.ts
VITE_API_BASE_URL=http://localhost:3000/api

# PURPOSE: Socket.io connection endpoint
# WHERE: frontend/src/lib/socket.ts
VITE_WS_URL=http://localhost:3000
